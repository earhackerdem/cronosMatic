# ── Project ──────────────────────────────────────────────
PROJECT_NAME=CronosMatic
COMPOSE_PROJECT_NAME=cronosmatic

# ── Backend (FastAPI) ────────────────────────────────────
BACKEND_PORT=8000
BACKEND_DEBUG=true
BACKEND_SECRET_KEY=change-me-in-production
BACKEND_CORS_ORIGINS=http://localhost:4200

# ── Frontend (Angular) ──────────────────────────────────
FRONTEND_PORT=4200
NODE_ENV=development

# ── Database (PostgreSQL + pgvector) ────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=cronosmatic
POSTGRES_USER=cronosmatic
POSTGRES_PASSWORD=change-me-in-production

# ── Composed URL (SQLAlchemy / asyncpg) ─────────────────
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
