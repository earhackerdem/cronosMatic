# ── Project ──────────────────────────────────────────────
PROJECT_NAME=CronosMatic
COMPOSE_PROJECT_NAME=cronosmatic

# ── Backend (FastAPI) ────────────────────────────────────
BACKEND_PORT=8000
BACKEND_DEBUG=true
BACKEND_SECRET_KEY=change-me-in-production
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4200  # 5173=Vite, 4200=legacy fallback
BACKEND_JWT_SECRET_KEY=change-me-in-production-jwt
BACKEND_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_STORAGE_BASE_URL=http://localhost:9000/cronosmatic

# ── S3 / Image Storage ────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cronosmatic-dev

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend (React) ────────────────────────────────────
FRONTEND_PORT=5173
NODE_ENV=development

# ── Database (PostgreSQL + pgvector) ────────────────────
# POSTGRES_HOST is used by Makefile for local tooling (alembic, psql).
# Inside Docker the backend connects to the service name "db" directly.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cronosmatic
POSTGRES_USER=cronosmatic
POSTGRES_PASSWORD=change-me-in-production

# ── pgAdmin ─────────────────────────────────────────────
PGADMIN_EMAIL=admin@cronosmatic.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
